# rust-quant-bot — exemple de configuration. COPIER en `.env` (jamais commité, cf. .gitignore).

# ── Général ──────────────────────────────────────────────────────────────────
DRY_RUN=true
PORT=8768
RUST_LOG=info
START_CASH=200

# ── Risque / circuit breaker ─────────────────────────────────────────────────
MAX_DRAWDOWN=20          # coupe l'exécution si equity ≤ START_CASH - MAX_DRAWDOWN

# ── LIVE (passage au réel) ───────────────────────────────────────────────────
# VERROU MATÉRIEL : laisser `false` tant que la signature EIP-712 n'est pas vérifiée.
# Même à `true`, aucun ordre ne part tant que sign_order_eip712 n'est pas implémenté/validé.
LIVE_ARMED=false

# Credentials L2 — générés EN AMONT (flow L1 hors bot), à NE JAMAIS committer.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_FUNDER_ADDRESS=      # adresse du deposit wallet (maker, sig_type 3)
POLY_PRIVATE_KEY=         # EOA qui signe l'EIP-712 — SECRET ABSOLU
