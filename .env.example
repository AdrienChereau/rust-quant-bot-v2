# rust-quant-bot — exemple de configuration. COPIER en `.env` (jamais commité, cf. .gitignore).

# ── Général ──────────────────────────────────────────────────────────────────
DRY_RUN=true
PORT=8768
RUST_LOG=info
START_CASH=200

# ── Risque / circuit breaker ─────────────────────────────────────────────────
MAX_DRAWDOWN=20          # coupe l'exécution si equity ≤ START_CASH - MAX_DRAWDOWN

# ── LIVE (passage au réel) ───────────────────────────────────────────────────
# VERROU MATÉRIEL : laisser `false` tant que la signature EIP-712 n'est pas vérifiée.
LIVE_ARMED=false

# Credentials L2 — générés EN AMONT via scripts/derive_poly_creds.py, à NE JAMAIS committer.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_PRIVATE_KEY=         # clé MetaMask exportée — SECRET ABSOLU
POLY_FUNDER_ADDRESS=      # sig_type 0 : adresse MetaMask | sig_type 2 : proxy Polymarket (settings)
POLY_SIGNER_ADDRESS=      # sig_type 0 : optionnel (= funder) | sig_type 2 : adresse MetaMask EOA
POLY_SIG_TYPE=2            # 0=EOA MetaMask | 2=Gnosis Safe proxy (défaut) | 3=deposit wallet (NON supporté)
