# ── Rôle du nœud ───────────────────────────────────────────────
# radar | executor | combined (dev local mono-process)
# Peut aussi être dérivé de AWS_REGION (ap-northeast-1 / eu-west-1).
BOT_ROLE=combined

# ── Sécurité : aucun ordre réel tant que DRY_RUN=true ──────────
DRY_RUN=true

# ── Réseau ─────────────────────────────────────────────────────
PORT=8767
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@depth20@100ms

# Transport du signal KILL (mode mono-rôle, deux terminaux) :
# Exécuteur : écoute sur SIGNAL_ADDR. Radar : envoie vers SIGNAL_TARGET.
SIGNAL_ADDR=127.0.0.1:9001
SIGNAL_TARGET=127.0.0.1:9001
USE_UDP_TRANSPORT=false

# ── Radar (J2) ─────────────────────────────────────────────────
OBI_DEPTH_LEVELS=5
OBI_THRESHOLD=0.85
VELOCITY_THRESHOLD=5.0

# ── Volatilité (J4) ────────────────────────────────────────────
# MONTÉ (truth protocol) : σ plus élevé → fair plus proche du mid. Tester 0.6→1.0.
VOLATILITY_FLOOR=0.80

# ── Signal MM : drift (correctif tendance) + skew OBI ──────────
DRIFT_HALFLIFE_SECS=25.0
DRIFT_CLAMP_K=2.0
OBI_SKEW=0.05

# ── Avellaneda-Stoikov + reward (J7) ───────────────────────────
# NB : γ/κ et le floor de vol sont à CALIBRER en paper. Avec les valeurs par
# défaut, le fair BS peut diverger fortement du mid du marché (vol 5min minuscule).
AS_GAMMA=0.1
AS_KAPPA=1.5
OUR_SIZE=50.0
REWARD_POOL_PER_MIN=1.0

# ── Spread MM (R2) ─────────────────────────────────────────────
# Demi-spread de base (cents) — remplace le terme A-S mal échelonné.
BASE_HALF_SPREAD_CENTS=2.0

# ── Bankroll / gates (R4) ──────────────────────────────────────
BANKROLL_FRACTION=0.02
MAX_NET_EXPOSURE_PCT=0.15
MIN_CASH_RESERVE_PCT=0.25
MAX_WINDOW_LOSS_PCT=0.10
MAX_ORDER_SIZE=100
MAX_POSITION=500
MAX_NET_SHARES=40
PAIRED_BUY_MARGIN=0.01
FLIP_SIZE=40
# NB : pas de MIN_EDGE_CENTS — on est un MM NEUTRE, pas un parieur directionnel.

# ── Exécution maker (R3) ───────────────────────────────────────
MAKER_FILL_PROB=0.2
MAKER_ONLY=true

# ── KILL / Panic stop (R5) ─────────────────────────────────────
KILL_PAUSE_SECS=5
PANIC_STOP_SECS=30
# Garde-fou 3 (TTE) : sous ce TTE (s), aplatir la jambe nette non-matchée (taker au bid).
FLATTEN_SECS=20

# ── Fusion CTF (J8/J11) ────────────────────────────────────────
MIN_MERGE_THRESHOLD=5.0
SAFETY_MULT=3.0

# ── Credentials Polymarket (J11, vide en mode paper) ───────────
# POLY_PRIVATE_KEY=0x...
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
# POLY_SIG_TYPE=3
# POLY_FUNDER=0x...
