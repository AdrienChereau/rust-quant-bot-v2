# ═══ RADAR TOKYO (.env) — calcule spot/σ/drift/OFI/OBI au plus près de Binance ═══
BOT_ROLE=radar
USE_UDP_TRANSPORT=true
# Adresse UDP de l'exécuteur Dublin (port 8080 déjà ouvert chez vous)
SIGNAL_TARGET=<IP_PRIVEE_DUBLIN>:8080
# Dashboard local du radar (optionnel, tunnel SSH pour y accéder)
PORT=8766
RUST_LOG=info
# Feed Binance (défaut : depth20@100ms — ne pas changer)
#BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@depth20@100ms
# Signal
DRIFT_HALFLIFE_SECS=25
VOLATILITY_FLOOR=0.80
OBI_THRESHOLD=0.85
VELOCITY_THRESHOLD=45
