# ═══ EXECUTOR DUBLIN (.env) — quotes maker + CLOB, signal reçu de Tokyo ═══
BOT_ROLE=executor
USE_UDP_TRANSPORT=true
# Écoute UDP des ticks Tokyo (port 8080 réglé chez vous)
SIGNAL_ADDR=0.0.0.0:8080
PORT=8767
RUST_LOG=info
# Dashboard accessible via Tailscale (l'interface tailscale0 y accède ;
# NE PAS ouvrir ce port dans le security group AWS public)
DASH_BIND=0.0.0.0
DRY_RUN=true            # PAPER — l'armement live est une étape séparée

# ── Copy Maker V8.4 (config validée en paper, ne pas modifier sans replay) ──
START_CASH=1000
STATE_PATH=data/paper_state_v8.json
TRADES_PATH=data/paper_trades_v8.jsonl
WINDOWS_PATH=data/paper_windows_v8.jsonl
SC_SLEEP_HOURS_UTC=
SC_REBATE_RATE=0.20
SC_MAX_CAPITAL_PER_MARKET=80
SC_MAX_CLIP_USDC=10
SC_CLIP_INTERVAL_S=2
SC_BASE_CLIP=10
SC_MAX_CLIP=30
SC_MAX_IMBALANCE=150
SC_COMPLETION_MAX_PRICE=0.99
SC_COMPLETION_MAX_PAIR=0.995
SC_STREAK_SOFT=2
SC_COMPLETION_RESERVE=0
MIN_MERGE_THRESHOLD=30
SC_TREND_CONFIRM_S=20
SC_DIRECTIONAL_MIN=0.40

# ── LIVE (étape B — inutilisés tant que DRY_RUN=true) ──
# Vos creds existants du monorepo restent valables ; il faudra en plus :
#POLY_SIG_TYPE=3            # deposit wallet — OBLIGATOIRE
#POLY_PRIVATE_KEY=          # clé du wallet
#POLY_API_KEY=
#POLY_API_SECRET=
#POLY_API_PASSPHRASE=
