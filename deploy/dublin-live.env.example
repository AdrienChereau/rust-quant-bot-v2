# ═══ EXECUTOR LIVE DUBLIN (.env.live) — ORDRES RÉELS sur le CLOB ═══
# ⚠️ Deux verrous : build `--features live` (deploy.sh live le fait) + LIVE_ARMED.
BOT_ROLE=executor
USE_UDP_TRANSPORT=true
SIGNAL_ADDR=0.0.0.0:8081        # 2e port UDP (le paper garde 8080) — cf. SIGNAL_TARGET2 à Tokyo
PORT=8771                       # dashboard live : http://<ip-tailscale>:8771
DASH_BIND=0.0.0.0
RUST_LOG=info
DRY_RUN=false                   # false = chemin live (mais rien ne part sans LIVE_ARMED)
LIVE_ARMED=false                # ⚠️ false = répétition générale (ordres signés, loggés, PAS postés)
                                # → passer à true SEULEMENT après validation des logs

# ── Credentials Polymarket (deposit wallet, sig_type 3) — reprendre du .env existant ──
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_FUNDER_ADDRESS=
POLY_SIGNER_ADDRESS=
POLY_PRIVATE_KEY=
POLY_SIG_TYPE=3
# ── Relayer (merge/redeem on-chain, gasless) — clé self-service :
#    polymarket.com → Settings → API Keys. Sans ces 2 lignes, merge/redeem
#    sont désactivés (le bot tient ses positions jusqu'à la résolution).
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# ── Stratégie : MÊMES maths que le paper, tailles micro (validation jour 1-2) ──
START_CASH=200                  # miroir comptable (le collatéral réel est lu au boot)
STATE_PATH=data/live_state.json
TRADES_PATH=data/live_trades.jsonl
WINDOWS_PATH=data/live_windows.jsonl
SC_SLEEP_HOURS_UTC=
SC_REBATE_RATE=0.20
SC_BANKROLL_PCT=0.30            # budget/fenêtre = 30% de la bankroll RÉELLE (recalculé à chaque fenêtre)
SC_MAX_CLIP_USDC=5              # ≥ min_order_size PM (5 parts) même à 90c — micro quand même
SC_CLIP_INTERVAL_S=2
SC_BASE_CLIP=6
SC_MAX_CLIP=10
SC_MAX_IMBALANCE=30
SC_COMPLETION_MAX_PRICE=0.99
SC_COMPLETION_MAX_PAIR=0.995
SC_STREAK_SOFT=9999
SC_COMPLETION_RESERVE=0
MIN_MERGE_THRESHOLD=30
SC_TREND_CONFIRM_S=20
SC_DIRECTIONAL_MIN=0.40
SC_OFI_CONFIRM=true
SC_OFI_MIN=0.15
SC_SYMMETRIC=true             # MODE SYMÉTRIQUE : 2 bids simultanés, paire garantie ≤99,5c, ZÉRO pari directionnel
