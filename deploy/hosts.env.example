# Copie en `hosts.env` (gitignored) et renseigne les hôtes. Utilisé par les scripts deploy/*.sh.
# Format : user@ip (clé SSH déjà configurée).

# Nœud LIVE (Dublin) — exécution réelle.
LIVE_HOST=ubuntu@REMPLACER_IP_DUBLIN
LIVE_DASH_PORT=8769

# Nœud PAPER (machine séparée) — simulation.
PAPER_HOST=ubuntu@REMPLACER_IP_PAPER
PAPER_DASH_PORT=8768

# Nœud RADAR (Tokyo) — émetteur de signaux.
RADAR_HOST=ubuntu@REMPLACER_IP_TOKYO
RADAR_DASH_PORT=8768

# Répertoire distant d'installation (identique sur les 3 nœuds).
REMOTE_DIR=/home/ubuntu/rust-quant-bot
